{
  "name": "auto-compta-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "dependencies": {
    "axios": "^1.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "recharts": "^2.9.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "desktop:react": "react-scripts build",
    "desktop:start": "electron .",
    "desktop:build": "electron-builder --win nsis"
  },
  "proxy": "http://127.0.0.1:8000",
  "build": {
    "extends": null,
    "appId": "com.auto-compta.desktop",
    "productName": "Auto Compta",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "electron/dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build",
        "to": "web/build"
      },
      {
        "from": "../dist/auto-compta-backend",
        "to": "backend"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": "nsis"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.12"
  }
}
